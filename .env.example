# Optional. If omitted, render-job resolves relative inputs from ./jobs.
JOBS_ROOT=./jobs

# Optional. If omitted, outputs go to ./renders.
RENDERS_ROOT=./renders

# Optional. Must stay inside ./public so Remotion can read audio via staticFile().
PUBLIC_AUDIO_ROOT=./public/audio

# Optional. If omitted, the script tries system ffmpeg/ffprobe, then npm fallback packages.
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# Optional. Recommended on Linux VPS if Chromium is not discovered by Remotion.
# Ubuntu 24.04 may install Chromium as /snap/bin/chromium.
REMOTION_BROWSER_EXECUTABLE=/usr/bin/chromium
